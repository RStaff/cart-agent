+  const line = fs
+    .readFileSync(filePath, "utf8")
+    .split(/\r?\n/)
+    .find((l) => l.startsWith(`${key}=`));
+  if (!line) return "";
+  return line
+    .slice(key.length + 1)
+    .trim()
+    .replace(/^["']|["']$/g, "");
