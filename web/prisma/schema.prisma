generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id          String       @id @default(cuid())
  key         String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  apiKey      String?
  emailFrom   String?
  name        String?
  provider    String?
  carts       Cart[]
  emailQueues EmailQueue[] @relation("Shop_EmailQueue")
}

model Cart {
  id                           String       @id @default(cuid())
  cartId                       String       @unique
  userEmail                    String
  items                        Json
  status                       String       @default("abandoned")
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  shopId                       String?
  attributedOrderId            String?
  attributedOrderValueCents    Int?
  attributedShopDomain         String?
  attributedSource             String?
  attributedCurrency           String?
  attributionMatchedAt         DateTime?
  attributionIsSynthetic       Boolean      @default(false)
  shop                         Shop?        @relation(fields: [shopId], references: [id])
  emailQueues                  EmailQueue[] @relation("Cart_EmailQueue")

  @@index([shopId])
  @@index([shopId, attributionIsSynthetic])
  @@index([attributedOrderId])
}

model EmailQueue {
  id          String      @id @default(cuid())
  shopId      String?
  cartId      String?
  to          String
  subject     String
  html        String
  status      EmailStatus @default(queued)
  runAt       DateTime    @default(now())
  attempts    Int         @default(0)
  error       String?
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  attachments Json?
  cart        Cart?       @relation("Cart_EmailQueue", fields: [cartId], references: [id])
  shop        Shop?       @relation("Shop_EmailQueue", fields: [shopId], references: [id])

  @@index([status, runAt])
}

enum EmailStatus {
  queued
  sending
  sent
  failed
}

enum JobStatus {
  queued
  running
  succeeded
  failed
  dead
}

enum EventVisibility {
  system
  merchant
}

model Job {
  id             String    @id @default(cuid())
  type           String
  shopDomain     String
  idempotencyKey String    @unique
  status         JobStatus @default(queued)
  payload        Json
  result         Json?
  errorKind      String?
  errorMessage   String?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  runAt          DateTime  @default(now())
  lockedAt       DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, runAt])
  @@index([type, status, runAt])
  @@index([shopDomain, createdAt])
}

model SystemEvent {
  id           String          @id @default(cuid())
  shopDomain   String
  eventType    String
  visibility   EventVisibility @default(system)
  relatedJobId String?
  payload      Json?
  createdAt    DateTime        @default(now())

  @@index([shopDomain, createdAt])
  @@index([eventType, createdAt])
  @@index([relatedJobId, createdAt])
}

model DecisionLog {
  id                String   @id @default(cuid())
  shopDomain        String
  cartToken         String?
  trigger           String
  decision          String
  decisionReason    String
  interventionType  String
  outcome           String   @default("unknown")
  decisionTimestamp DateTime
  outcomeTimestamp  DateTime?
  cartValueCents    Int?
  sessionMarker     String?
  validationMode    Boolean  @default(false)
  relatedEventId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shopDomain, decisionTimestamp])
  @@index([cartToken, decisionTimestamp])
  @@index([relatedEventId])
}

model Invite {
  id                  String   @id @default(cuid())
  inviterShopDomain   String
  targetEmail         String?
  targetStoreDomain   String?
  sourceSurface       String
  createdAt           DateTime @default(now())
  clickedAt           DateTime?
  installStartedAt    DateTime?
  installCompletedAt  DateTime?
  sessionReachedAt    DateTime?
  installedShopDomain String?
  installPath         String?
  sessionSurface      String?
  createdInValidation Boolean @default(false)

  @@index([inviterShopDomain, createdAt])
  @@index([targetEmail])
  @@index([targetStoreDomain])
  @@index([installedShopDomain])
}
/* --- abando billing + usage models --- */
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  stripeCustomerId String?  @unique
  stripeSubStatus  String?
  freeCredits      Int      @default(20)
  creditsResetAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usages           Usage[]
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  cost      Int
  meta      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}


/// Daily per-store aggregates for Abando v1 → StaffordOS exports




// DailyAggregates + related fields for Abando v1
model DailyAggregate {
  id                     Int      @id @default(autoincrement())
  storeId                Int
  date                   DateTime

  cartsCreated           Int      @default(0)
  cartsAbandoned         Int      @default(0)
  cartsRecovered         Int      @default(0)

  recoveryAttemptsSent   Int      @default(0)
  recoveryClicks         Int      @default(0)
  recoveriesCount        Int      @default(0)

  potentialRevenue       Decimal  @default(0)
  revenueRecovered       Decimal  @default(0)

  abandonmentRate        Decimal?
  recoveryRate           Decimal?
  clickThroughRate       Decimal?
  conversionRate         Decimal?

  avgCartValue           Decimal?
  avgTimeToRecoveryHours Decimal?

  createdAt              DateTime @default(now())

  @@unique([storeId, date])
  @@index([storeId, date])
}
